proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - 'همکاری_ملی'
      - 'جاویدشاه'
      - 'KingRezaPahlavi'
      - '🇸🇮 SI | VLESS | @filterk0sh #1'
      - '🇳🇱 NL | VLESS | @orange_vpns #1'
      - '🇦🇪 AE | VLESS | @orange_vpns #1'
