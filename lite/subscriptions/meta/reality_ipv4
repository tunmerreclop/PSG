proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇩🇪 DE | 🔒 VLESS | @configasli [6]'
      - '🇫🇷 FR | 🔒 VLESS | @configasli [7]'
      - '🇩🇪 DE | 🔒 VLESS | @grizzlyvpn [8]'
