proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - 'همکاری_ملی'
      - 'جاویدشاه'
      - 'KingRezaPahlavi'
      - '🇷🇺 RU | VLESS | @config_proxy #1'
      - '🇷🇺 RU | VLESS | @config_proxy #2'
      - '🇸🇮 SI | VLESS | @filterk0sh #1'
      - '🇸🇪 SE | VLESS | @proxyfn #1'
      - '🇨🇭 CH | VLESS | @proxyfn #1'
