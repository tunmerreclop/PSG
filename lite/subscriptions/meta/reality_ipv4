proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - 'همکاری_ملی'
      - 'جاویدشاه'
      - 'KingRezaPahlavi'
      - '🇺🇦 UA | VLESS | @armod_iran #1'
      - '🇷🇺 RU | VLESS | @mtproxy22_v2ray #1'
      - '🇸🇪 SE | VLESS | @proxyfn #1'
      - '🇨🇭 CH | VLESS | @proxyfn #1'
