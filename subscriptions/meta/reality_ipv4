    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - 'همکاری_ملی'
      - 'جاویدشاه'
      - 'KingRezaPahlavi'
      - '🇳🇱 NL | VLESS | @config_proxy #1'
      - '🇸🇮 SI | VLESS | @filterk0sh #1'
