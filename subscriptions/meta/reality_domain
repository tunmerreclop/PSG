      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - 'همکاری_ملی'
      - 'جاویدشاه'
      - 'KingRezaPahlavi'
      - '🇦🇹 AT | VLESS | @config_proxy #1'
