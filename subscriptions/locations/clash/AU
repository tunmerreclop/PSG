mixed-port: 7890
allow-lan: true
log-level: info
external-controller: 0.0.0.0:9090

dns:
  enabled: true
  listen: 0.0.0.0:1053
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query
  fake-ip-filter:
    - '*.lan'
    - '*.local'
    - '*.msftconnecttest.com'
    - '*.msftncsi.com'
    - '+.pool.ntp.org'

proxies: 
  - {"name": "🇦🇺 AU | VMESS | @dailyv2ray #1", "server": "104.31.16.104", "port": 80, "type": "vmess", "skip-cert-verify": true, "uuid": "12c25b50-f6c7-11ed-b230-205c6d5f5d78", "alterId": 0, "cipher": "auto", "network": "ws", "tls": false, "ws-opts": {"path": "/qmbdkyzn", "headers": {"Host": "us-4.0rd.net"}}}
  - {"name": "🇦🇺 AU | VMESS | @khoneproxy #1", "server": "us-2.0rd.net", "port": 443, "type": "vmess", "skip-cert-verify": true, "uuid": "597888c0-a318-11ed-b536-205c6d5f5d78", "alterId": 0, "cipher": "auto", "network": "ws", "tls": true, "ws-opts": {"path": "/tq98e0yk", "headers": {"Host": "us-2.0rd.net"}}}
  - {"name": "🇦🇺 AU | VMESS | @v2ray_free_conf #1", "server": "hopev2ray.ddns.net", "port": 443, "type": "vmess", "skip-cert-verify": true, "uuid": "17bbb590-ec28-11ed-b334-205c6d5f5d78", "alterId": 0, "cipher": "auto", "network": "ws", "tls": true, "ws-opts": {"path": "/@SINA_TEC", "headers": {"Host": "pl.0rd.net"}}}

proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇦🇺 AU | VMESS | @dailyv2ray #1'
      - '🇦🇺 AU | VMESS | @khoneproxy #1'
      - '🇦🇺 AU | VMESS | @v2ray_free_conf #1'

  - name: 🌍 Global Media
    type: select
    proxies:
      - 🚀 Proxy
      - ♻️ Auto
      - 🎯 Direct

  - name: 🎯 Direct
    type: select
    proxies:
      - DIRECT

  - name: 🛑 Ad Block
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🐟 Fallback
    type: select
    proxies:
      - 🚀 Proxy
      - 🎯 Direct

rules:
  - DOMAIN-KEYWORD,adservice,🛑 Ad Block
  - DOMAIN-SUFFIX,googlesyndication.com,🛑 Ad Block
  - DOMAIN-SUFFIX,netflix.com,🌍 Global Media
  - DOMAIN-SUFFIX,nflxvideo.net,🌍 Global Media
  - DOMAIN-SUFFIX,disneyplus.com,🌍 Global Media
  - DOMAIN-KEYWORD,youtube,🌍 Global Media
  - DOMAIN-SUFFIX,t.me,🚀 Proxy
  - DOMAIN-SUFFIX,telegram.org,🚀 Proxy
  - DOMAIN-SUFFIX,openai.com,🚀 Proxy
  - DOMAIN-SUFFIX,lan,🎯 Direct
  - DOMAIN-SUFFIX,local,🎯 Direct
  - IP-CIDR,127.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,192.168.0.0/16,🎯 Direct,no-resolve
  - IP-CIDR,10.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,172.16.0.0/12,🎯 Direct,no-resolve
  - GEOIP,IR,🎯 Direct
  - MATCH,🐟 Fallback
