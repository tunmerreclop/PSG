proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇺🇸 US | VMESS | @freev2rays #1'
      - '🇺🇸 US | VMESS | @serverv2ray00 #1'
