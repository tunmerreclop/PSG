  - {"name": "🇦🇪 AE | VLESS | @orange_vpns #1", "server": "78.40.194.14", "port": 19465, "type": "vless", "skip-cert-verify": true, "uuid": "a6690136-c109-45e6-be13-a45f7cb9eb2a", "network": "tcp", "tls": false, "udp": true, "client-fingerprint": "chrome"}
  - {"name": "🇦🇪 AE | VLESS | @v2rayngconfig #1", "server": "s2.ihigkgloybfhygkih.pw", "port": 8443, "type": "vless", "skip-cert-verify": true, "uuid": "1408e7de-a086-41e9-997d-06612883f3ae", "network": "tcp", "tls": true, "udp": true, "client-fingerprint": "chrome"}

proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇦🇪 AE | VLESS | @ai_duet #1'
      - '🇦🇪 AE | VLESS | @mtproxy22_v2ray #1'
      - '🇦🇪 AE | VLESS | @orange_vpns #1'
      - '🇦🇪 AE | VLESS | @v2rayngconfig #1'

  - name: 🌍 Global Media
    type: select
    proxies:
      - 🚀 Proxy
      - ♻️ Auto
      - 🎯 Direct

  - name: 🎯 Direct
    type: select
    proxies:
      - DIRECT

  - name: 🛑 Ad Block
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🐟 Fallback
    type: select
    proxies:
      - 🚀 Proxy
      - 🎯 Direct

rules:
  - DOMAIN-KEYWORD,adservice,🛑 Ad Block
  - DOMAIN-SUFFIX,googlesyndication.com,🛑 Ad Block
  - DOMAIN-SUFFIX,netflix.com,🌍 Global Media
  - DOMAIN-SUFFIX,nflxvideo.net,🌍 Global Media
  - DOMAIN-SUFFIX,disneyplus.com,🌍 Global Media
  - DOMAIN-KEYWORD,youtube,🌍 Global Media
  - DOMAIN-SUFFIX,t.me,🚀 Proxy
  - DOMAIN-SUFFIX,telegram.org,🚀 Proxy
  - DOMAIN-SUFFIX,openai.com,🚀 Proxy
  - DOMAIN-SUFFIX,lan,🎯 Direct
  - DOMAIN-SUFFIX,local,🎯 Direct
  - IP-CIDR,127.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,192.168.0.0/16,🎯 Direct,no-resolve
  - IP-CIDR,10.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,172.16.0.0/12,🎯 Direct,no-resolve
  - GEOIP,IR,🎯 Direct
  - MATCH,🐟 Fallback
