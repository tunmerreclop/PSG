  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇮🇷 IR | VLESS | @config_proxy #1'
      - '🇮🇷 IR | VLESS | @config_proxy #2'
      - '🇮🇷 IR | VLESS | @config_proxy #3'
