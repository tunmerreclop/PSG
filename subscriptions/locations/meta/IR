proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇮🇷 IR | VLESS | @ai_duet'
      - '🇮🇷 IR | VLESS | @config_proxy'
      - '🇮🇷 IR | VLESS | @frev2rayng'
