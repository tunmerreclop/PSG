proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇷🇺 RU | VLESS | @config_proxy #1'
      - '🇷🇺 RU | VLESS | @config_proxy #2'
      - '🇷🇺 RU | VLESS | @config_proxy #3'
      - '🇷🇺 RU | VLESS | @config_proxy #4'
