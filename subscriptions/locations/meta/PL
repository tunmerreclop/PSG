mixed-port: 7890
allow-lan: true
log-level: info
external-controller: 0.0.0.0:9090

dns:
  enabled: true
  listen: 0.0.0.0:1053
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  default-nameserver:
    - 223.5.5.5
    - 119.29.29.29
  nameserver:
    - https://doh.pub/dns-query
    - https://dns.alidns.com/dns-query
  fake-ip-filter:
    - '*.lan'
    - '*.local'
    - '*.msftconnecttest.com'
    - '*.msftncsi.com'
    - '+.pool.ntp.org'

proxies: 
  - {"name": "همکاری_ملی", "server": "127.0.0.1", "port": 443, "type": "vless", "skip-cert-verify": true, "uuid": "00000000-0000-0000-0000-000000000000", "network": "ws", "tls": false, "udp": true, "client-fingerprint": "chrome", "ws-opts": {"path": "", "headers": {"Host": "127.0.0.1"}}}
  - {"name": "جاویدشاه", "server": "127.0.0.1", "port": 443, "type": "vless", "skip-cert-verify": true, "uuid": "00000000-0000-0000-0000-000000000000", "network": "ws", "tls": false, "udp": true, "client-fingerprint": "chrome", "ws-opts": {"path": "", "headers": {"Host": "127.0.0.1"}}}
  - {"name": "KingRezaPahlavi", "server": "127.0.0.1", "port": 443, "type": "vless", "skip-cert-verify": true, "uuid": "00000000-0000-0000-0000-000000000000", "network": "ws", "tls": false, "udp": true, "client-fingerprint": "chrome", "ws-opts": {"path": "", "headers": {"Host": "127.0.0.1"}}}
  - {"name": "🇵🇱 PL | VLESS | @proxy48", "server": "172.64.198.137", "port": 443, "type": "vless", "skip-cert-verify": true, "uuid": "d9eb0df3-3190-4447-86b6-656fe5ff1119", "network": "tcp", "tls": false, "udp": true, "client-fingerprint": "chrome"}
  - {"name": "🇵🇱 PL | VLESS | @vmesc", "server": "144.31.0.77", "port": 8443, "type": "vless", "skip-cert-verify": true, "uuid": "05071212-5966-430d-a53b-d4472581ddc8", "network": "tcp", "tls": false, "udp": true, "client-fingerprint": "chrome"}

proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - 'همکاری_ملی'
      - 'جاویدشاه'
      - 'KingRezaPahlavi'
      - '🇵🇱 PL | VLESS | @proxy48'
      - '🇵🇱 PL | VLESS | @vmesc'

  - name: 🌍 Global Media
    type: select
    proxies:
      - 🚀 Proxy
      - ♻️ Auto
      - 🎯 Direct

  - name: 🎯 Direct
    type: select
    proxies:
      - DIRECT

  - name: 🛑 Ad Block
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🐟 Fallback
    type: select
    proxies:
      - 🚀 Proxy
      - 🎯 Direct

rules:
  - DOMAIN-KEYWORD,adservice,🛑 Ad Block
  - DOMAIN-SUFFIX,googlesyndication.com,🛑 Ad Block
  - DOMAIN-SUFFIX,netflix.com,🌍 Global Media
  - DOMAIN-SUFFIX,nflxvideo.net,🌍 Global Media
  - DOMAIN-SUFFIX,disneyplus.com,🌍 Global Media
  - DOMAIN-KEYWORD,youtube,🌍 Global Media
  - DOMAIN-SUFFIX,t.me,🚀 Proxy
  - DOMAIN-SUFFIX,telegram.org,🚀 Proxy
  - DOMAIN-SUFFIX,openai.com,🚀 Proxy
  - DOMAIN-SUFFIX,lan,🎯 Direct
  - DOMAIN-SUFFIX,local,🎯 Direct
  - IP-CIDR,127.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,192.168.0.0/16,🎯 Direct,no-resolve
  - IP-CIDR,10.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,172.16.0.0/12,🎯 Direct,no-resolve
  - GEOIP,IR,🎯 Direct
  - MATCH,🐟 Fallback
