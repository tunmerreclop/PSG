proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇵🇱 PL | VLESS | @config_proxy #1'
      - '🇵🇱 PL | VLESS | @config_proxy #2'
      - '🇵🇱 PL | VLESS | @config_proxy #3'
      - '🇵🇱 PL | VLESS | @config_proxy #4'
