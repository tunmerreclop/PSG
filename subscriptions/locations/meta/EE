  - {"name": "🇪🇪 EE | VLESS | @config_proxy #4", "server": "77.239.126.122", "port": 7443, "type": "vless", "skip-cert-verify": true, "uuid": "9b4a17a2-6845-4924-a81a-20b7591ba9f9", "network": "tcp", "tls": false, "udp": true, "client-fingerprint": "chrome"}
  - {"name": "🇪🇪 EE | VLESS | @prrofile_purple #1", "server": "est.pink-service.ru", "port": 443, "type": "vless", "skip-cert-verify": true, "uuid": "9c7d89ae-daf3-45c2-84d6-a7447e9123f9", "network": "tcp", "tls": true, "udp": true, "client-fingerprint": "chrome", "reality-opts": {"public-key": "", "short-id": ""}}

proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇪🇪 EE | VLESS | @config_proxy #1'
      - '🇪🇪 EE | VLESS | @config_proxy #2'
      - '🇪🇪 EE | VLESS | @config_proxy #3'
      - '🇪🇪 EE | VLESS | @config_proxy #4'
      - '🇪🇪 EE | VLESS | @prrofile_purple #1'

  - name: 🌍 Global Media
    type: select
    proxies:
      - 🚀 Proxy
      - ♻️ Auto
      - 🎯 Direct

  - name: 🎯 Direct
    type: select
    proxies:
      - DIRECT

  - name: 🛑 Ad Block
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🐟 Fallback
    type: select
    proxies:
      - 🚀 Proxy
      - 🎯 Direct

rules:
  - DOMAIN-KEYWORD,adservice,🛑 Ad Block
  - DOMAIN-SUFFIX,googlesyndication.com,🛑 Ad Block
  - DOMAIN-SUFFIX,netflix.com,🌍 Global Media
  - DOMAIN-SUFFIX,nflxvideo.net,🌍 Global Media
  - DOMAIN-SUFFIX,disneyplus.com,🌍 Global Media
  - DOMAIN-KEYWORD,youtube,🌍 Global Media
  - DOMAIN-SUFFIX,t.me,🚀 Proxy
  - DOMAIN-SUFFIX,telegram.org,🚀 Proxy
  - DOMAIN-SUFFIX,openai.com,🚀 Proxy
  - DOMAIN-SUFFIX,lan,🎯 Direct
  - DOMAIN-SUFFIX,local,🎯 Direct
  - IP-CIDR,127.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,192.168.0.0/16,🎯 Direct,no-resolve
  - IP-CIDR,10.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,172.16.0.0/12,🎯 Direct,no-resolve
  - GEOIP,IR,🎯 Direct
  - MATCH,🐟 Fallback
