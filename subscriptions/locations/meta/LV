  - {"name": "🇱🇻 LV | VLESS | @free4allvpn", "server": "195.135.252.28", "port": 443, "type": "vless", "skip-cert-verify": true, "uuid": "099dbf2d-a8e0-406e-a85f-eba0ac9a68aa", "network": "tcp", "tls": true, "udp": true, "client-fingerprint": "chrome", "reality-opts": {"public-key": "", "short-id": ""}}

proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇱🇻 LV | VLESS | @config_proxy'
      - '🇱🇻 LV | VLESS | @filtershekan_channel'
      - '🇱🇻 LV | VLESS | @free4allvpn'

  - name: 🌍 Global Media
    type: select
    proxies:
      - 🚀 Proxy
      - ♻️ Auto
      - 🎯 Direct

  - name: 🎯 Direct
    type: select
    proxies:
      - DIRECT

  - name: 🛑 Ad Block
    type: select
    proxies:
      - REJECT
      - DIRECT

  - name: 🐟 Fallback
    type: select
    proxies:
      - 🚀 Proxy
      - 🎯 Direct

rules:
  - DOMAIN-KEYWORD,adservice,🛑 Ad Block
  - DOMAIN-SUFFIX,googlesyndication.com,🛑 Ad Block
  - DOMAIN-SUFFIX,netflix.com,🌍 Global Media
  - DOMAIN-SUFFIX,nflxvideo.net,🌍 Global Media
  - DOMAIN-SUFFIX,disneyplus.com,🌍 Global Media
  - DOMAIN-KEYWORD,youtube,🌍 Global Media
  - DOMAIN-SUFFIX,t.me,🚀 Proxy
  - DOMAIN-SUFFIX,telegram.org,🚀 Proxy
  - DOMAIN-SUFFIX,openai.com,🚀 Proxy
  - DOMAIN-SUFFIX,lan,🎯 Direct
  - DOMAIN-SUFFIX,local,🎯 Direct
  - IP-CIDR,127.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,192.168.0.0/16,🎯 Direct,no-resolve
  - IP-CIDR,10.0.0.0/8,🎯 Direct,no-resolve
  - IP-CIDR,172.16.0.0/12,🎯 Direct,no-resolve
  - GEOIP,IR,🎯 Direct
  - MATCH,🐟 Fallback
