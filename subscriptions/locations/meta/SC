proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇸🇨 SC | VLESS | @arv2ray #1'
      - '🇸🇨 SC | VLESS | @arv2ray #2'
