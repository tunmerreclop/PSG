proxy-groups:
  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇮🇹 IT | VLESS | @Fr33C0nfig'
      - '🇮🇹 IT | VLESS | @config_proxy'
      - '🇮🇹 IT | VLESS | @flyv2ray'
      - '🇮🇹 IT | VLESS | @prrofile_purple'
      - '🇮🇹 IT | VLESS | @prrofile_purple'
