  - {"name": "🇰🇷 KR | VLESS | @hope_net", "server": "124.80.75.68", "port": 15772, "type": "vless", "skip-cert-verify": true, "uuid": "d342d11e-d424-4583-b36e-524ab1f0afa4", "network": "tcp", "tls": true, "udp": true, "client-fingerprint": "chrome"}
