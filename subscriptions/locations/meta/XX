  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇽🇽 XX | VLESS | @ai_duet #1'
      - '🇽🇽 XX | VLESS | @ai_duet #2'
      - '🇽🇽 XX | VLESS | @garnet_free #1'
      - '🇽🇽 XX | VLESS | @garnet_free #2'
